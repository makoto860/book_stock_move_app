<div class="stocks-container">
  <h1>現在の在庫一覧</h1>
  <div class="stocks-search">
    <%= form_with url: stocks_path, method: :get, local: true do %>
      <div class="stock-search-field">
        <%= text_field_tag :q, params[:q], placeholder: "タイトル、現在の在庫数で検索" %>
      </div>
      <%= submit_tag "検索", class: "stock-search-button" %>
    <% end %>
  </div>
  <div class="sort-book-link-list a">
    <%= link_to "在庫多い順", stocks_path(sort: "quantity_desc") %>
    <%= link_to "在庫少ない順", stocks_path(sort: "quantity_asc") %>
    <%= link_to "作成日が新しい順", stocks_path(sort: "created_at") %>
  </div>
</div>
<table class="books-table">
  <thead>
    <tr>
      <th>タイトル</th>
      <th>場所の名前</th>
      <th>現在の数</th>
      <th>作成日</th>
    </tr>
  </thead>

  <% @stocks.each do |stock| %>
      <tr>
        <td><%= stock.book.title %></td>
        <td><%= stock.location.name %></td>
        <td class="<%= stock_color_class(stock) %>"><%= stock.quantity %></td>
        <td><%= I18n.l(stock.created_at, format: :datetime_jp) %></td>
      </tr>
  <% end %>
</table>
