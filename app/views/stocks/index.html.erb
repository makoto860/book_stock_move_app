<h1>在庫一覧,stocks/index.html.erb</h1>
<table>
  <tr>
    <th>タイトル</th>
    <th>ロケーション</th>
    <th>在庫数</th>
  </tr>
  <% @stocks.each do |stock| %>
    <tr>
      <td><%= stock.book.title %></td>
      <td><%= stock.location.name %></td>
      <td><%= stock.quantity %></td>
    </tr>
  <% end %>
</table>
<%= link_to "在庫を追加する", new_stock_path %>
