<h1>教科書の情報</h1>
<table>
  <tr>
    <th>本のID</th>
    <td><%= @book.id %></td>
  </tr>
  <tr>
    <th>タイトル</th>
    <td><%= @book.title %></td>
  </tr>
  <tr>
    <th>棚の番号</th>
    <td><%=@book.rack_number %></td>
  </tr>
  <tr>
    <th>ISBN</th>
    <td><%= @book.isbn %></td>
  </tr>
  <tr>
    <th>備考欄</th>
    <td><%= @book.note %></td>
  </tr>
  <tr>
    <th>取り寄せ日時</th>
    <td><%= I18n.l(@book.special_order_date_time, format: :datetime_jp) %></td>
  </tr>
  <tr>
    <th>注文日時</th>
    <td><%= I18n.l(@book.order_date_time, format: :datetime_jp) %></td>
  </tr>
</table>
<p><%= link_to "教科書一覧", :books %></p>
