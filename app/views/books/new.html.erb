<h1>教科書を新しく作成,books/new.html.erb</h1>
<%= form_with model: @book do |f| %>
  <%= render 'shared/error_messages', model: @book %>
  <table>
    <tr>
      <th><%= f.label :title, "タイトル" %></th>
      <td><%= f.text_field :title %></td>
    </tr>
    <tr>
      <th><%= f.label :book_quantity, "教科書の数" %></th>
      <td><%= f.number_field :book_quantity, min: 0 %></td>
    </tr>
    <tr>
      <th><%= f.label :rack_number, "棚の番号" %></th>
      <td><%= f.text_field :rack_number %></td>
    </tr>
    <tr>
      <th><%= f.label :isbn, "ISBN" %></th>
      <td><%= f.text_field :isbn %></td>
    </tr>
    <tr>
      <th><%= f.label :note, "備考欄" %></th>
      <td><%= f.text_field :note %></td>
    </tr>
  </table>
  <div>
    <ul>
      <li><%= f.submit "教科書を登録する"%></li>
      <li><%= link_to "教科書一覧に戻る", :books %></li>
    </ul>
  </div>
<% end %>
